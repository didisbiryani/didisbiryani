rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email != null && (
        request.auth.token.email.lower() == 'didisbiryani@gmail.com' || 
        request.auth.token.email.lower() == 'admin@gmail.com' ||
        (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())) && 
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data.role == 'super_admin')
      );
    }

    function isOrderManager() {
      return request.auth != null && request.auth.token.email != null && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())) && 
         get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data.role == 'order_manager')
      );
    }

    function hasTabPermission(tabName) {
      return request.auth != null && request.auth.token.email != null && (
        isSuperAdmin() ||
        (
          exists(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())) &&
          (
            (get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data.role == 'order_manager' && (tabName == 'orders' || tabName == 'messages' || tabName == 'delivery-boys')) ||
            (get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data.role == 'custom' && 'allowedTabs' in get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data && tabName in get(/databases/$(database)/documents/team_members/$(request.auth.token.email.lower())).data.allowedTabs)
          )
        )
      );
    }

    // 0. TEAM MEMBERS (RBAC):
    match /team_members/{emailId} {
      // Any authenticated user can read team members (required for login check). Only super admins can write.
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // 1. MENU: Anyone can read the menu. Only the admin can add/edit/delete menu items.
    match /menu/{menuId} {
      allow read: if true;
      allow write: if hasTabPermission('menu') || hasTabPermission('manage-menu');
    }

    // 2. ORDERS:
    match /orders/{orderId} {
      // Allow create:
      // - Order managers can create any order.
      // - Regular customer can only create their own order, with 'Pending' status, 'Pending' payment status, and isManual = false.
      allow create: if request.auth != null && (
        hasTabPermission('orders') || hasTabPermission('manual-order') ||
        (
          request.resource.data.userId == request.auth.uid &&
          (!('status' in request.resource.data) || request.resource.data.status == 'Pending' || request.resource.data.status == 'Payment Pending') &&
          (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus == 'Pending') &&
          (!('isManual' in request.resource.data) || request.resource.data.isManual == false)
        )
      );
      
      // Allow GET (fetching a single order by direct ID) for anyone so payment links work without requiring login.
      allow get: if true;
      
      // Allow LIST (querying all orders) only if logged-in customer is querying their own, OR order manager, OR driver.
      allow list: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        hasTabPermission('orders') || hasTabPermission('order-history') || 
        request.auth.token.email == 'driver@didisbiryani.in'
      );
      
      // Admin, driver, and the order owner are permitted to update orders.
      allow update: if request.auth != null && (
        hasTabPermission('orders') || 
        request.auth.token.email == 'driver@didisbiryani.in' ||
        request.auth.uid == resource.data.userId
      );
      
      // Only admin/order manager is permitted to delete orders.
      allow delete: if hasTabPermission('orders');
    }

    // Delivery Boys:
    match /deliveryBoys/{boyId} {
      allow read, write: if request.auth != null && (
        hasTabPermission('delivery-boys') || 
        request.auth.token.email == 'driver@didisbiryani.in'
      );
    }

    // 3. USERS & WALLET LEDGERS:
    match /users/{userId} {
      // Allow Order Managers to read users so they can see customer details on orders.
      allow read: if request.auth != null && (hasTabPermission('customers') || hasTabPermission('orders') || request.auth.uid == userId);
      allow create: if request.auth != null;
      
      // Regular users can only update if they are not increasing their walletBalance cache.
      allow update: if request.auth != null && (
        isSuperAdmin() ||
        (
          request.auth.uid == userId &&
          (
            !('walletBalance' in request.resource.data) || 
            !('walletBalance' in resource.data) || 
            request.resource.data.walletBalance <= resource.data.walletBalance
          )
        )
      );
      allow delete: if isSuperAdmin();
      
      // Wallet Entries Ledger:
      // - Only Admin can create or delete wallet entries.
      // - Standard users can update their own entries ONLY to decrement remainingAmount (no infinite money exploits).
      match /walletEntries/{entryId} {
        allow read: if request.auth != null && (hasTabPermission('wallet') || hasTabPermission('customers') || request.auth.uid == userId);
        allow create, delete: if hasTabPermission('wallet') || hasTabPermission('customers');
        allow update: if request.auth != null && (
          hasTabPermission('wallet') || hasTabPermission('customers') ||
          (
            request.auth.uid == userId &&
            request.resource.data.remainingAmount <= resource.data.remainingAmount &&
            request.resource.data.amount == resource.data.amount &&
            request.resource.data.expiryDate == resource.data.expiryDate &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.createdAt == resource.data.createdAt
          )
        );
      }
    }

    // 4. MESSAGES:
    match /messages/{messageId} {
      allow create: if request.auth != null && (
        request.resource.data.customerId == request.auth.uid ||
        hasTabPermission('messages')
      );
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.customerId || 
        hasTabPermission('messages')
      );
    }
    
    // 5. STORE SETTINGS (RESTAURANT STATUS):
    match /storeSettings/{document=**} {
      allow read: if true;
      allow write: if hasTabPermission('restaurants');
    }
    
    // 7. COUPONS:
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if hasTabPermission('coupons');
    }
    
    // 8. SETTINGS:
    match /settings/{docId} {
      allow read: if true;
      allow write: if hasTabPermission('settings');
    }
    
    // 9. MAIL (Trigger Email Extension - Locked down to prevent quota spam):
    match /mail/{mailId} {
      allow read, write: if isSuperAdmin();
    }
    
    // 10. BANNERS:
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if hasTabPermission('storefront');
    }
    
    // 11. COUNTERS:
    // - Order number counter. Any logged-in user can read.
    // - Can only increment by exactly 1 in transactions.
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        counterId == 'orders' && (
          (resource == null && request.resource.data.count == 1) ||
          (resource != null && request.resource.data.count == resource.data.count + 1)
        )
      );
    }
    
  }
}
