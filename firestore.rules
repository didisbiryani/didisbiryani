rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. MENU: Anyone can read the menu. Only the admin can add/edit/delete menu items.
    match /menu/{menuId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }

    // 2. ORDERS:
    match /orders/{orderId} {
      // Allow create:
      // - Admin can create any order.
      // - Regular customer can only create their own order, with 'Pending' status, 'Pending' payment status, and isManual = false.
      allow create: if request.auth != null && (
        (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com') ||
        (
          request.resource.data.userId == request.auth.uid &&
          (!('status' in request.resource.data) || request.resource.data.status == 'Pending') &&
          (!('paymentStatus' in request.resource.data) || request.resource.data.paymentStatus == 'Pending') &&
          (!('isManual' in request.resource.data) || request.resource.data.isManual == false)
        )
      );
      
      // Allow GET (fetching a single order by direct ID) for anyone so payment links work without requiring login.
      allow get: if true;
      
      // Allow LIST (querying all orders) only if logged-in customer is querying their own, OR admin, OR driver.
      allow list: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.token.email == 'didisbiryani@gmail.com' || 
        request.auth.token.email == 'admin@gmail.com' || 
        request.auth.token.email == 'driver@didisbiryani.in'
      );
      
      // Only admin and driver are permitted to update orders.
      allow update: if request.auth != null && (
        request.auth.token.email == 'didisbiryani@gmail.com' || 
        request.auth.token.email == 'admin@gmail.com' || 
        request.auth.token.email == 'driver@didisbiryani.in'
      );
      
      // Only admin is permitted to delete orders.
      allow delete: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }

    // Delivery Boys:
    match /deliveryBoys/{boyId} {
      allow read, write: if request.auth != null && (
        request.auth.token.email == 'didisbiryani@gmail.com' || 
        request.auth.token.email == 'admin@gmail.com' || 
        request.auth.token.email == 'driver@didisbiryani.in'
      );
    }

    // 3. USERS & WALLET LEDGERS:
    match /users/{userId} {
      allow read: if request.auth != null && ((request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com') || request.auth.uid == userId);
      allow create: if request.auth != null;
      
      // Regular users can only update if they are not increasing their walletBalance cache.
      allow update: if request.auth != null && (
        (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com') ||
        (
          request.auth.uid == userId &&
          (
            !('walletBalance' in request.resource.data) || 
            !('walletBalance' in resource.data) || 
            request.resource.data.walletBalance <= resource.data.walletBalance
          )
        )
      );
      allow delete: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
      
      // Wallet Entries Ledger:
      // - Only Admin can create or delete wallet entries.
      // - Standard users can update their own entries ONLY to decrement remainingAmount (no infinite money exploits).
      match /walletEntries/{entryId} {
        allow read: if request.auth != null && ((request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com') || request.auth.uid == userId);
        allow create, delete: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
        allow update: if request.auth != null && (
          (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com') ||
          (
            request.auth.uid == userId &&
            request.resource.data.remainingAmount <= resource.data.remainingAmount &&
            request.resource.data.amount == resource.data.amount &&
            request.resource.data.expiryDate == resource.data.expiryDate &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.createdAt == resource.data.createdAt
          )
        );
      }
    }

    // 4. MESSAGES:
    match /messages/{messageId} {
      allow create: if request.auth != null && (
        request.resource.data.customerId == request.auth.uid ||
        request.auth.token.email == 'didisbiryani@gmail.com' || 
        request.auth.token.email == 'admin@gmail.com'
      );
      allow read, write: if request.auth != null && (
        request.auth.uid == resource.data.customerId || 
        request.auth.token.email == 'didisbiryani@gmail.com' || 
        request.auth.token.email == 'admin@gmail.com'
      );
    }
    
    // 5. STORE SETTINGS (RESTAURANT STATUS):
    match /storeSettings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }
    
    // 7. COUPONS:
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }
    
    // 8. SETTINGS:
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }
    
    // 9. MAIL (Trigger Email Extension - Locked down to prevent quota spam):
    match /mail/{mailId} {
      allow read, write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }
    
    // 10. BANNERS:
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.email == 'didisbiryani@gmail.com' || request.auth.token.email == 'admin@gmail.com');
    }
    
    // 11. COUNTERS:
    // - Order number counter. Any logged-in user can read.
    // - Can only increment by exactly 1 in transactions.
    match /counters/{counterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        counterId == 'orders' && (
          (resource == null && request.resource.data.count == 1) ||
          (resource != null && request.resource.data.count == resource.data.count + 1)
        )
      );
    }
    
  }
}
